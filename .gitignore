.DS_Store

# Node / Next.js
**/node_modules/
**/.next/
**/out/
**/build/
**/.turbo/

# Logs
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/.pnpm-debug.log*

# Env (never commit secrets) — allow *.env.example
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local
!**/.env.example

# Python / FastAPI
**/__pycache__/
**/*.py[cod]
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.venv/
**/venv/
*.egg-info/
dist/
.python-version

# Large ingested justice opinion chunks (CourtListener / RAG)
**/data/justices/*/opinions/*.json

# Cursor / IDE
.idea/
.vscode/
.cursor/

# OS
Thumbs.db
